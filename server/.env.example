# ============================================
# SERVER CONFIG
# ============================================
PORT=5000
NODE_ENV=development
CLIENT_URL=http://localhost:5173

# ============================================
# DATABASE
# ============================================
# Local MongoDB (default for MongoDB Community Server)
MONGO_URI=mongodb://127.0.0.1:27017/attendance_system

# ============================================
# JWT AUTHENTICATION
# ============================================
# Use long random strings in production. Generate with:
# node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_ACCESS_SECRET=replace_this_with_a_long_random_secret_for_access_tokens
JWT_REFRESH_SECRET=replace_this_with_a_long_random_secret_for_refresh_tokens
JWT_ACCESS_EXPIRES=15m
JWT_REFRESH_EXPIRES=7d

# ============================================
# EMAIL (NODEMAILER) - for OTP verification & password reset
# Free option: Gmail with an App Password
# (Google Account -> Security -> 2-Step Verification -> App Passwords)
# ============================================
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your_email@gmail.com
EMAIL_PASS=your_16_char_app_password
EMAIL_FROM="Attendance System <your_email@gmail.com>"

# ============================================
# OTP CONFIG
# ============================================
OTP_EXPIRES_MINUTES=10
OTP_LENGTH=6

# ============================================
# RATE LIMITING
# ============================================
RATE_LIMIT_WINDOW_MINUTES=15
RATE_LIMIT_MAX_REQUESTS=200
AUTH_RATE_LIMIT_MAX_REQUESTS=10

# ============================================
# SEED ADMIN (used by `npm run seed`)
# ============================================
SEED_ADMIN_NAME=Head Admin
SEED_ADMIN_EMAIL=admin@college.edu
SEED_ADMIN_PASSWORD=ChangeMe@123
